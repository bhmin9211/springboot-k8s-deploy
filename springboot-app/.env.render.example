SPRING_PROFILES_ACTIVE=render
SERVER_PORT=8081

SPRING_DATASOURCE_URL=jdbc:mariadb://<your-db-host>:3306/k8s_dashboard
SPRING_DATASOURCE_USERNAME=<your-db-user>
SPRING_DATASOURCE_PASSWORD=<your-db-password>

APP_JWT_SECRET=<change-this-to-a-long-random-secret>
APP_JWT_VALIDITY_MS=3600000
APP_CORS_ALLOWED_ORIGINS=https://<your-frontend-domain>
APP_KUBERNETES_COMMANDS_ENABLED=false
